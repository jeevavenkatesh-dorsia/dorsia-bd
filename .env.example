# Vite exposes only VITE_* vars to the browser (safe for publishable/anon key).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Local seed script only — never add to Vercel or commit real values.
# Use legacy service_role JWT or new sb_secret_ key from Supabase → Settings → API.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-secret-key
